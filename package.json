{
  "name": "pandora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "build": "tsc && vite build",
    "electron:dev": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win nsis portable",
    "cap:sync": "npm run build && cap sync android",
    "apk:debug": "set \"JAVA_HOME=C:\\Program Files\\Microsoft\\jdk-21.0.11.10-hotspot\" && set \"ANDROID_HOME=%LOCALAPPDATA%\\Android\\Sdk\" && set \"ANDROID_SDK_ROOT=%LOCALAPPDATA%\\Android\\Sdk\" && npm run build && cap sync android && cd android && gradlew.bat assembleDebug",
    "test": "vitest run"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^9.1.2",
    "@capacitor/share": "^7.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.pandora.passwords",
    "productName": "Pandora",
    "directories": {
      "output": "release"
    },
    "icon": "build/icon.ico",
    "files": [
      "dist/**/*",
      "build/icon.ico",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Pandora"
    }
  }
}
